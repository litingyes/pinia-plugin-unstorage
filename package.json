{
    "name": "pinia-plugin-unstorage",
    "version": "0.2.2",
    "private": false,
    "description": "The best persistence plugin for pinia.",
    "keywords": [
        "persist",
        "pinia",
        "storage",
        "vue"
    ],
    "homepage": "https://github.com/litingyes/pinia-plugin-unstorage#readme",
    "bugs": {
        "url": "https://github.com/litingyes/pinia-plugin-unstorage/issues"
    },
    "license": "MIT",
    "author": "litingyes <luz.liting@gmail.com> (https://litingyes.top/)",
    "files": [
        "dist"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": {
                "import": "./dist/index.d.mts",
                "require": "./dist/index.d.cts"
            },
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./nuxt": {
            "types": {
                "import": "./dist/module.d.mts",
                "require": "./dist/module.d.cts"
            },
            "import": "./dist/module.mjs",
            "require": "./dist/module.cjs"
        }
    },
    "scripts": {
        "lint": "vp check",
        "format": "vp check --fix",
        "prebuild": "cd examples/nuxt && pnpm install && pnpm prepare",
        "build": "nuxt-module-build build",
        "release": "bumpp"
    },
    "dependencies": {
        "@nuxt/kit": "latest",
        "destr": "^2.0.5",
        "es-toolkit": "^1.45.1",
        "unstorage": "^1.17.4"
    },
    "devDependencies": {
        "@nuxt/module-builder": "latest",
        "@nuxt/schema": "latest",
        "@types/node": "22",
        "bumpp": "latest",
        "typescript": "^5.7.3",
        "vite-plus": "latest"
    },
    "peerDependencies": {
        "pinia": "3",
        "vue": "3"
    },
    "lint-staged": {
        "*": "eslint --fix"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint"
        }
    },
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
